{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "moduleResolution": "bundler",   // ← le fix

    "paths": {
      "@miya/ui": ["./libs/ui/src/index.ts"],
      "@miya/kernel": ["./libs/kernel/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
